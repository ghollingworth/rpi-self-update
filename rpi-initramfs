#!/bin/bash
set -euo pipefail

# rpi-initramfs — build initramfs with optional payload and deploy to boot partition
#
# Usage: sudo ./rpi-initramfs [--add-file <path>]... [--add-binary <path>]... [-y|--yes]
#        sudo ./rpi-initramfs --usbboot <dir> [--add-file <path>]... [--add-binary <path>]...
#
# --add-file <path>    Copy file or directory into /payload/ inside initramfs (by basename)
# --add-binary <path>  Copy host binary + shared libs into initramfs
# --add-module <name>  Include extra kernel module beyond the WiFi defaults
#                      (e.g. nvme, hid-logitech)
# --wifi-ssid <ssid>   Embed WiFi SSID so the initramfs can associate when
# --wifi-psk <psk>     Ethernet is unavailable. PSK is hashed with
#                      wpa_passphrase before being written to the initramfs.
# --usbboot <dir>      Build a rpiboot-compatible directory instead of deploying locally
# --dry-run            Build initramfs but only show what would be deployed
# -y, --yes            Skip "Reboot now?" prompt
#
# No --add-file = no entry-point = drops to shell on boot

DATA_DIR="/usr/share/rpi-self-update"
BUILD_DIR=$(mktemp -d /tmp/rpi-initramfs.XXXXXX)
INITRAMFS_SRC="$DATA_DIR/initramfs"
BOOT_DIR="/boot/firmware"

cleanup_build() {
    rm -rf "$BUILD_DIR"
}
trap cleanup_build EXIT

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

die() {
    echo -e "${RED}ERROR: $*${NC}" >&2
    exit 1
}

usage() {
    echo "Usage: sudo $0 [--add-file <path>]... [--add-binary <path>]... [-y|--yes]"
    echo "       sudo $0 --usbboot <dir> [--add-file <path>]... [--add-binary <path>]..."
    echo ""
    echo "Options:"
    echo "  --add-file <path>    Copy file or directory into /payload/ inside initramfs"
    echo "  --add-binary <path>  Copy host binary + shared libs into initramfs"
    echo "  --add-module <name>  Include extra kernel module beyond WiFi defaults"
    echo "                       (e.g. nvme, hid-logitech)"
    echo "  --wifi-ssid <ssid>   Embed WiFi SSID for fallback association"
    echo "  --wifi-psk <psk>     WiFi password (hashed with wpa_passphrase before"
    echo "                       being written into the initramfs)"
    echo "  --usbboot <dir>      Build a rpiboot-compatible directory instead of deploying"
    echo "  --dry-run            Build initramfs but only show what would be deployed"
    echo "  -y, --yes            Skip reboot prompt and reboot immediately"
    echo ""
    echo "No --add-file = no entry-point = drops to shell on boot."
    exit 1
}

# Parse arguments
ADD_FILES=()
ADD_BINARIES=()
ADD_MODULES=()
WIFI_SSID=""
WIFI_PSK=""
AUTO_YES=0
NO_REBOOT=0
DRY_RUN=0
USBBOOT_DIR=""

while [ $# -gt 0 ]; do
    case "$1" in
        --add-file)
            [ -n "${2:-}" ] || die "--add-file requires a path argument"
            ADD_FILES+=("$2"); shift 2 ;;
        --add-binary)
            [ -n "${2:-}" ] || die "--add-binary requires a path argument"
            ADD_BINARIES+=("$2"); shift 2 ;;
        --add-module)
            [ -n "${2:-}" ] || die "--add-module requires a module name"
            ADD_MODULES+=("$2"); shift 2 ;;
        --wifi-ssid)
            [ -n "${2:-}" ] || die "--wifi-ssid requires an SSID argument"
            WIFI_SSID="$2"; shift 2 ;;
        --wifi-psk)
            [ -n "${2:-}" ] || die "--wifi-psk requires a password argument"
            WIFI_PSK="$2"; shift 2 ;;
        --usbboot)
            [ -n "${2:-}" ] || die "--usbboot requires a directory argument"
            USBBOOT_DIR="$2"; shift 2 ;;
        --dry-run)
            DRY_RUN=1; shift ;;
        -y|--yes)
            AUTO_YES=1; shift ;;
        --no-reboot)
            NO_REBOOT=1; shift ;;
        --help|-h)
            usage ;;
        *)
            die "Unknown option: $1" ;;
    esac
done

# Validate
[ "$(id -u)" -eq 0 ] || die "Must be run as root"

# Validate all --add-file paths exist
for f in "${ADD_FILES[@]+"${ADD_FILES[@]}"}"; do
    [ -e "$f" ] || die "--add-file path does not exist: $f"
done

# Validate all --add-binary paths exist
for b in "${ADD_BINARIES[@]+"${ADD_BINARIES[@]}"}"; do
    [ -f "$b" ] || die "--add-binary path does not exist: $b"
done

echo -e "${BOLD}Raspberry Pi Initramfs Builder${NC}"
echo ""

# ==================== BUILD INITRAMFS ====================

# Create directory structure
for d in proc sys dev dev/pts tmp run boot etc bin sbin usr/bin usr/sbin scripts payload; do
    mkdir -p "$BUILD_DIR/$d"
done

# Copy static busybox from host package (busybox-static)
echo "Installing busybox..."
cp /usr/bin/busybox "$BUILD_DIR/bin/busybox"
chmod 755 "$BUILD_DIR/bin/busybox"

# Create busybox symlinks
BUSYBOX_APPLETS=(
    sh ash mount umount mkdir mdev ifconfig ip udhcpc route
    wget ssl_client xzcat dd sha256sum cat echo ls sleep sync
    reboot poweroff blkid head cut tr wc sed grep awk basename
    clear vi dmesg mknod ln chmod chown rm cp mv touch date
    printf test expr seq tail tee mktemp df du free
    switch_root pivot_root kill killall ps setsid cttyhack
    tar gzip gunzip losetup partprobe blockdev
)

echo "Creating busybox symlinks..."
for applet in "${BUSYBOX_APPLETS[@]}"; do
    ln -sf busybox "$BUILD_DIR/bin/$applet"
done

# Create minimal device nodes
echo "Creating device nodes..."
mknod -m 622 "$BUILD_DIR/dev/console" c 5 1
mknod -m 666 "$BUILD_DIR/dev/null" c 1 3
mknod -m 666 "$BUILD_DIR/dev/zero" c 1 5
mknod -m 666 "$BUILD_DIR/dev/tty" c 5 0

# Install a kernel module (by name) plus its dependencies into a target dir.
# Args: <mod_name> <kver> <dest_dir>
install_kmod() {
    local mod_name="$1"
    local kver="$2"
    local dest_dir="$3"
    local kname
    kname=$(echo "$mod_name" | tr '-' '_')
    # Skip if already installed for this kernel
    [ -f "$dest_dir/$kname.ko" ] && return 0

    # Find the .ko.xz file (try both _ and - variants of the name)
    local mod_file
    mod_file=$(find "/lib/modules/$kver" \( -name "${kname}.ko.xz" -o -name "$(echo "$mod_name" | tr '_' '-').ko.xz" \) 2>/dev/null | head -1)
    [ -z "$mod_file" ] && return 1

    # Install dependencies first (from modules.dep)
    local mod_relpath
    mod_relpath=$(echo "$mod_file" | sed "s|^/lib/modules/$kver/||")
    local dep_line
    dep_line=$(grep "^${mod_relpath}:" "/lib/modules/$kver/modules.dep" 2>/dev/null || true)
    if [ -n "$dep_line" ]; then
        local deps
        deps=$(echo "$dep_line" | cut -d: -f2-)
        for dep_path in $deps; do
            local dep_name
            dep_name=$(basename "$dep_path" .ko.xz)
            dep_name=$(echo "$dep_name" | tr '-' '_')
            install_kmod "$dep_name" "$kver" "$dest_dir" 2>/dev/null || true
        done
    fi

    mkdir -p "$dest_dir"
    xzcat "$mod_file" > "$dest_dir/$kname.ko"
    # Record the install order as a deps-first load order for init. Because
    # this happens after the recursive dep-install above, every module's
    # deps have already been appended — init can insmod straight through
    # the file with no retries and no "Unknown symbol" dmesg noise.
    echo "$kname" >> "$dest_dir/loadorder"
    MOD_COUNT=$((MOD_COUNT + 1))
    echo "  $mod_name"
    return 0
}

# Default modules: just enough for WiFi in the recovery initramfs.
# install_kmod pulls in transitive deps (rfkill, etc.) via modules.dep.
# Storage drivers (nvme, usb-storage), HID, etc. are built into the Pi
# kernel for most use cases — add them with --add-module if you need them.
#
# brcmfmac is split across a core module and chip-vendor sub-modules
# (bca/cyw/wcc). On Pi 4 the BCM4345 needs brcmfmac + brcmfmac-wcc to
# scan and associate; brcmfmac alone is enough to bring the interface
# up but not enough to actually use it. Ship all three so any Pi
# variant's chip works.
#
# Previously we shipped every module currently loaded on the host, which
# produced a lot of "failed to load" noise in the initramfs log for
# modules that aren't actually needed in recovery.
DEFAULT_MODULES=(
    brcmfmac brcmfmac-bca brcmfmac-cyw brcmfmac-wcc
    brcmutil cfg80211 mac80211
)

# Regular (tryboot) mode: ship modules for THIS kernel (build host == target).
# Usbboot mode: skip — target hardware/kernel is unknown, modules are handled later.
if [ -z "$USBBOOT_DIR" ]; then
    echo "Installing kernel modules..."
    KVER=$(uname -r)
    KMOD_DST="$BUILD_DIR/lib/modules"
    MOD_COUNT=0

    MODULES_TO_INSTALL=("${DEFAULT_MODULES[@]}")
    for mod in "${ADD_MODULES[@]+"${ADD_MODULES[@]}"}"; do
        MODULES_TO_INSTALL+=("$mod")
    done

    for mod in "${MODULES_TO_INSTALL[@]}"; do
        install_kmod "$mod" "$KVER" "$KMOD_DST" || echo "  WARNING: module $mod not found for kernel $KVER"
    done

    if [ "$MOD_COUNT" -gt 0 ]; then
        echo "  Installed $MOD_COUNT modules into /lib/modules ($KVER)"
    else
        echo "  No modules installed"
    fi
fi

# Bundle CA certificates
echo "Bundling CA certificates..."
mkdir -p "$BUILD_DIR/etc/ssl/certs"
if [ -f /etc/ssl/certs/ca-certificates.crt ]; then
    cp /etc/ssl/certs/ca-certificates.crt "$BUILD_DIR/etc/ssl/certs/"
else
    echo "WARNING: /etc/ssl/certs/ca-certificates.crt not found, HTTPS may not work"
fi

# Copy shared libraries needed by a binary into the initramfs
install_shared_libs() {
    local bin_path="$1"

    ldd "$bin_path" 2>/dev/null | while read -r line; do
        local lib_path
        lib_path=$(echo "$line" | grep -oP '=> \K/\S+' || true)
        if [ -z "$lib_path" ]; then
            lib_path=$(echo "$line" | grep -oP '^\s*\K/\S+' || true)
        fi
        [ -z "$lib_path" ] && continue
        [ ! -f "$lib_path" ] && continue

        local lib_dest="$BUILD_DIR$lib_path"
        [ -f "$lib_dest" ] && continue

        mkdir -p "$(dirname "$lib_dest")"
        cp "$lib_path" "$lib_dest"
    done

    # Ensure dynamic linker is present
    local linker="/lib/ld-linux-aarch64.so.1"
    if [ -f "$linker" ] && [ ! -f "$BUILD_DIR$linker" ]; then
        mkdir -p "$(dirname "$BUILD_DIR$linker")"
        cp "$linker" "$BUILD_DIR$linker"
    fi
}

# Install a host binary and its shared libraries into the initramfs
install_dynamic_binary() {
    local bin_path="$1"
    local bin_name
    bin_name=$(basename "$bin_path")

    if [ ! -f "$bin_path" ]; then
        echo "WARNING: $bin_path not found, skipping"
        return 1
    fi

    # Copy binary
    local dest_dir="$BUILD_DIR$(dirname "$bin_path")"
    mkdir -p "$dest_dir"
    if [ ! -f "$dest_dir/$bin_name" ]; then
        cp "$bin_path" "$dest_dir/$bin_name"
        chmod 755 "$dest_dir/$bin_name"
        echo "  Installed: $bin_path"
    fi

    install_shared_libs "$bin_path"
}

# Dropbear SSH server (from host package dropbear-bin)
echo "Installing dropbear SSH server..."
install_dynamic_binary /usr/sbin/dropbear
install_dynamic_binary /usr/bin/dropbearkey

# WiFi stack — wpa_supplicant + iw + firmware.
# Kernel modules (brcmfmac, cfg80211, mac80211, brcmutil) are listed in
# DEFAULT_MODULES above; install_kmod pulls them in plus their deps.
echo "Installing WiFi stack..."
install_dynamic_binary /usr/sbin/wpa_supplicant
install_dynamic_binary /usr/bin/wpa_passphrase
install_dynamic_binary /usr/sbin/iw

# Embed WiFi credentials into the initramfs, if provided. Hash the PSK
# with wpa_passphrase so the plaintext never lands on disk. init sources
# /etc/wifi.env in start_network_and_ssh, so the bare-initramfs case can
# fall back to WiFi just like rpi-self-update does.
if [ -n "$WIFI_SSID" ]; then
    if [ -n "$WIFI_PSK" ]; then
        command -v wpa_passphrase >/dev/null 2>&1 || \
            die "wpa_passphrase not found (install wpasupplicant)"
        WIFI_PSK_HASH=$(wpa_passphrase "$WIFI_SSID" "$WIFI_PSK" 2>/dev/null | \
            awk -F= '/^[[:space:]]*psk=/ {print $2; exit}')
        [ -n "$WIFI_PSK_HASH" ] || die "wpa_passphrase failed to hash PSK"
    else
        WIFI_PSK_HASH=""
    fi
    cat > "$BUILD_DIR/etc/wifi.env" <<WIFI_ENV
WIFI_SSID="$WIFI_SSID"
WIFI_PSK_HASH=$WIFI_PSK_HASH
WIFI_ENV
    chmod 600 "$BUILD_DIR/etc/wifi.env"
    if [ -n "$WIFI_PSK_HASH" ]; then
        echo "  Embedded WiFi creds for SSID '$WIFI_SSID' (PSK hashed)"
    else
        echo "  Embedded WiFi config for open SSID '$WIFI_SSID'"
    fi
elif [ -n "$WIFI_PSK" ]; then
    die "--wifi-psk requires --wifi-ssid"
fi

# brcmfmac firmware — copy the Pi's brcm firmware so the driver can load.
# These files are small enough (~10 MB) to bundle wholesale; glob keeps us
# agnostic between Pi 4 (43455) and other variants.
if [ -d /lib/firmware/brcm ]; then
    mkdir -p "$BUILD_DIR/lib/firmware/brcm"
    cp /lib/firmware/brcm/brcmfmac* "$BUILD_DIR/lib/firmware/brcm/" 2>/dev/null || true
    FW_COUNT=$(ls "$BUILD_DIR/lib/firmware/brcm/" 2>/dev/null | wc -l)
    echo "  Copied $FW_COUNT brcmfmac firmware files"
fi

# Regulatory database — the kernel's wireless stack refuses to bring up some
# interfaces without this. Pair .db with its signature .p7s.
for f in regulatory.db regulatory.db.p7s; do
    if [ -f "/lib/firmware/$f" ]; then
        cp "/lib/firmware/$f" "$BUILD_DIR/lib/firmware/$f"
        echo "  Copied firmware/$f"
    fi
done
# wpa_supplicant needs /var/run to be writable for its control socket
mkdir -p "$BUILD_DIR/var/run"

# Convert OpenSSH host keys to dropbear format
mkdir -p "$BUILD_DIR/etc/dropbear"
echo "  Converting OpenSSH host keys to dropbear format..."
for keytype in ed25519 rsa ecdsa; do
    src="/etc/ssh/ssh_host_${keytype}_key"
    dst="$BUILD_DIR/etc/dropbear/dropbear_${keytype}_host_key"
    if [ -f "$src" ]; then
        if dropbearconvert openssh dropbear "$src" "$dst" 2>/dev/null; then
            echo "    Converted: $keytype"
        else
            echo "    WARNING: Failed to convert $keytype, generating fresh key"
            dropbearkey -t "$keytype" -f "$dst" 2>&1 | head -1
        fi
    fi
done

# Set up user credentials for SSH login
INITRAMFS_USER="${SUDO_USER:-$USER}"
CURRENT_USER_HOME=$(eval echo "~$INITRAMFS_USER")

mkdir -p "$BUILD_DIR/root/.ssh"
if [ -f "$CURRENT_USER_HOME/.ssh/authorized_keys" ]; then
    cp "$CURRENT_USER_HOME/.ssh/authorized_keys" "$BUILD_DIR/root/.ssh/authorized_keys"
    chmod 600 "$BUILD_DIR/root/.ssh/authorized_keys"
    echo "  Copied authorized_keys from $CURRENT_USER_HOME"
else
    echo "  WARNING: No authorized_keys found at $CURRENT_USER_HOME/.ssh/authorized_keys"
fi

# Create /etc/passwd
echo "root:x:0:0:root:/root:/bin/sh" > "$BUILD_DIR/etc/passwd"
echo "${INITRAMFS_USER}:x:0:0:${INITRAMFS_USER}:/root:/bin/sh" >> "$BUILD_DIR/etc/passwd"
echo "nobody:x:65534:65534:nobody:/nonexistent:/bin/sh" >> "$BUILD_DIR/etc/passwd"

# Copy password hash from /etc/shadow
PASS_HASH=$(grep "^${INITRAMFS_USER}:" /etc/shadow 2>/dev/null | cut -d: -f2)
if [ -n "$PASS_HASH" ] && [ "$PASS_HASH" != "!" ] && [ "$PASS_HASH" != "*" ]; then
    echo "root:${PASS_HASH}:19000:0:99999:7:::" > "$BUILD_DIR/etc/shadow"
    echo "${INITRAMFS_USER}:${PASS_HASH}:19000:0:99999:7:::" >> "$BUILD_DIR/etc/shadow"
    chmod 640 "$BUILD_DIR/etc/shadow"
    echo "  Copied password hash for $INITRAMFS_USER"
else
    echo "  WARNING: No password hash found for $INITRAMFS_USER — key auth only"
    echo "root:*:19000:0:99999:7:::" > "$BUILD_DIR/etc/shadow"
    chmod 640 "$BUILD_DIR/etc/shadow"
fi

echo "root:x:0:" > "$BUILD_DIR/etc/group"
echo "/bin/sh" > "$BUILD_DIR/etc/shells"

# Save hostname
hostname > "$BUILD_DIR/etc/hostname"
echo "  Saved hostname: $(hostname)"

# Copy mke2fs config
if [ -f /etc/mke2fs.conf ]; then
    cp /etc/mke2fs.conf "$BUILD_DIR/etc/mke2fs.conf"
    echo "  Copied: /etc/mke2fs.conf"
fi

# Copy init script and helpers
echo "Installing init and scripts..."
cp "$INITRAMFS_SRC/init" "$BUILD_DIR/init"
chmod 755 "$BUILD_DIR/init"

for script in network.sh udhcpc.script; do
    cp "$INITRAMFS_SRC/scripts/$script" "$BUILD_DIR/scripts/$script"
    chmod 755 "$BUILD_DIR/scripts/$script"
done

# Install restore command
cp "$INITRAMFS_SRC/scripts/restore" "$BUILD_DIR/sbin/restore"
chmod 755 "$BUILD_DIR/sbin/restore"

# MOTD for SSH sessions
cat > "$BUILD_DIR/etc/motd" <<'MOTD'

  Raspberry Pi Self-Update Initramfs
  -----------------------------------
  Type "restore" to clean up and reboot back to the normal OS.
  (A hard reboot or power cycle will also return to the normal system.)

MOTD

# ==================== ADD BINARIES ====================

if [ ${#ADD_BINARIES[@]} -gt 0 ]; then
    echo ""
    echo "Installing additional binaries..."
    for bin in "${ADD_BINARIES[@]}"; do
        install_dynamic_binary "$bin"
    done
fi

# ==================== ADD FILES ====================

if [ ${#ADD_FILES[@]} -gt 0 ]; then
    echo ""
    echo "Adding payload files..."
    for f in "${ADD_FILES[@]}"; do
        base=$(basename "$f")
        if [ -d "$f" ]; then
            cp -r "$f" "$BUILD_DIR/payload/$base"
            echo "  Added directory: $base"
        else
            cp "$f" "$BUILD_DIR/payload/$base"
            echo "  Added file: $base"
        fi
        # Make initramfs-run executable
        if [ "$base" = "initramfs-run" ]; then
            chmod +x "$BUILD_DIR/payload/$base"
        fi
    done
fi

# ==================== BUILD CPIO + GZIP ====================

echo ""
echo "Building initramfs..."
OUTPUT_DIR="/tmp/rpi-initramfs-output"
OUTPUT_GZ="$OUTPUT_DIR/initramfs.gz"
mkdir -p "$OUTPUT_DIR"
(cd "$BUILD_DIR" && find . -print0 | cpio --null -ov --format=newc 2>/dev/null | gzip -9 > "$OUTPUT_GZ")

SIZE=$(stat -c%s "$OUTPUT_GZ")
SIZE_KB=$((SIZE / 1024))
echo ""
echo "Built: $OUTPUT_GZ ($SIZE_KB KB)"
echo "Busybox: $(stat -c%s "$BUILD_DIR/bin/busybox" | awk '{printf "%.1f MB", $1/1024/1024}')"

# ==================== DEPLOY ====================

if [ -n "$USBBOOT_DIR" ]; then
    # ---- usbboot mode: assemble rpiboot-compatible directory ----
    # Goal: bootable on any 64-bit-capable Pi (Pi 3/4/5, CM3/4/5, Zero 2)
    echo ""
    echo "Assembling usbboot directory: $USBBOOT_DIR"
    mkdir -p "$USBBOOT_DIR"

    # ---- GPU firmware blobs ----
    # bootcode.bin: BCM2837 (Pi 3 / CM3 / Zero 2 — no EEPROM)
    # start*.elf + fixup*.dat: BCM2837 GPU firmware
    # start4*.elf + fixup4*.dat: BCM2711 (Pi 4 / CM4) GPU firmware
    # Pi 5 (BCM2712) loads firmware from EEPROM and doesn't use these files.
    for f in bootcode.bin start.elf start_cd.elf start_db.elf start_x.elf \
             fixup.dat fixup_cd.dat fixup_db.dat fixup_x.dat \
             start4.elf start4cd.elf start4db.elf start4x.elf \
             fixup4.dat fixup4cd.dat fixup4db.dat fixup4x.dat; do
        if [ -f "$BOOT_DIR/$f" ]; then
            cp "$BOOT_DIR/$f" "$USBBOOT_DIR/$f"
        fi
    done
    echo "  Copied: GPU firmware (bootcode/start/fixup variants)"

    # ---- Kernels ----
    # kernel8.img: generic ARMv8 — Pi 3, Pi 4, CM3, CM4, Zero 2
    # kernel_2712.img: Pi 5 / CM5 (BCM2712)
    KERNELS_COPIED=()
    for k in kernel8.img kernel_2712.img; do
        if [ -f "$BOOT_DIR/$k" ]; then
            cp "$BOOT_DIR/$k" "$USBBOOT_DIR/$k"
            KERNELS_COPIED+=("$k")
        fi
    done
    if [ ${#KERNELS_COPIED[@]} -eq 0 ]; then
        die "no kernel images found in $BOOT_DIR (need kernel8.img or kernel_2712.img)"
    fi
    echo "  Copied: ${KERNELS_COPIED[*]}"

    # ---- Device tree blobs for all 64-bit-capable boards ----
    # bcm2710-*: BCM2837 (Pi 3, CM3, Zero 2)
    # bcm2711-*: BCM2711 (Pi 4, CM4)
    # bcm2712-*: BCM2712 (Pi 5, CM5)
    DTB_COUNT=0
    for prefix in bcm2710 bcm2711 bcm2712; do
        for dtb in "$BOOT_DIR/${prefix}"*.dtb; do
            [ -f "$dtb" ] || continue
            cp "$dtb" "$USBBOOT_DIR/"
            DTB_COUNT=$((DTB_COUNT + 1))
        done
    done
    echo "  Copied: $DTB_COUNT device tree blobs (bcm2710/2711/2712)"

    # ---- Overlays ----
    if [ -d "$BOOT_DIR/overlays" ]; then
        mkdir -p "$USBBOOT_DIR/overlays"
        cp "$BOOT_DIR/overlays/"*.dtbo "$USBBOOT_DIR/overlays/" 2>/dev/null || true
        echo "  Copied: overlays/"
    fi

    # ---- USB gadget serial modules ----
    # Different boards run different kernels. For each kernel image we ship,
    # find the matching modules directory and install gadget modules into
    # /lib/modules/<kver>/ inside the initramfs. Init picks the right dir
    # at boot via $(uname -r).
    extract_kver() {
        # Extract a kernel version string like "X.Y.Z+rpt-rpi-v8" from a kernel image.
        # Pi kernel images are gzip-compressed, so decompress first.
        # grep -m1 + `|| true` to avoid SIGPIPE under `set -o pipefail`.
        local img="$1"
        local reader=cat
        case "$(file -b "$img" 2>/dev/null)" in
            *gzip*) reader=zcat ;;
        esac
        "$reader" "$img" 2>/dev/null | strings 2>/dev/null | grep -oE -m1 '[0-9]+\.[0-9]+\.[0-9]+\+rpt-rpi-(v8|2712)' || true
    }

    GADGET_KVERS=()
    for k in "${KERNELS_COPIED[@]}"; do
        kv=$(extract_kver "$USBBOOT_DIR/$k")
        if [ -z "$kv" ]; then
            echo "  WARNING: could not extract kernel version from $k"
            continue
        fi
        if [ ! -d "/lib/modules/$kv" ]; then
            # Fall back to newest matching family
            case "$k" in
                kernel8.img)        kv=$(ls -1 /lib/modules/ | grep '+rpt-rpi-v8$' | sort -V | tail -1) ;;
                kernel_2712.img)    kv=$(ls -1 /lib/modules/ | grep '+rpt-rpi-2712$' | sort -V | tail -1) ;;
            esac
        fi
        if [ -n "$kv" ] && [ -d "/lib/modules/$kv" ]; then
            GADGET_KVERS+=("$kv")
        else
            echo "  WARNING: no modules directory for $k (looked for $kv)"
        fi
    done

    GADGET_MODS=(libcomposite g_serial)
    for kv in "${GADGET_KVERS[@]+"${GADGET_KVERS[@]}"}"; do
        dest="$BUILD_DIR/lib/modules/$kv"
        echo "  Installing USB gadget modules for $kv..."
        MOD_COUNT=0
        for m in "${GADGET_MODS[@]}"; do
            install_kmod "$m" "$kv" "$dest" || echo "    WARNING: $m not found in $kv"
        done
        # Plus any user-requested --add-module entries
        for m in "${ADD_MODULES[@]+"${ADD_MODULES[@]}"}"; do
            install_kmod "$m" "$kv" "$dest" || true
        done
    done

    # ---- Rebuild initramfs with the per-kernel module directories ----
    echo "  Rebuilding initramfs with gadget modules..."
    (cd "$BUILD_DIR" && find . -print0 | cpio --null -ov --format=newc 2>/dev/null | gzip -9 > "$OUTPUT_GZ")
    cp "$OUTPUT_GZ" "$USBBOOT_DIR/initramfs.gz"
    SIZE=$(stat -c%s "$OUTPUT_GZ")
    SIZE_KB=$((SIZE / 1024))
    echo "  Copied: initramfs.gz ($SIZE_KB KB)"

    # ---- config.txt ----
    cat > "$USBBOOT_DIR/config.txt" <<'USBBOOT_CFG'
# rpi-initramfs usbboot config — bootable on any 64-bit Pi
initramfs initramfs.gz followkernel
dtoverlay=dwc2,dr_mode=peripheral
uart_2ndstage=1
USBBOOT_CFG
    echo "  Created: config.txt"

    # ---- cmdline.txt ----
    echo "console=serial0,115200 console=tty1 console=ttyGS0" > "$USBBOOT_DIR/cmdline.txt"
    echo "  Created: cmdline.txt"

    echo ""
    echo -e "${GREEN}usbboot directory ready.${NC}"
    echo "  Size: $SIZE_KB KB (initramfs)"
    echo "  Kernels: ${KERNELS_COPIED[*]}"
    echo "  DTBs: $DTB_COUNT (Pi 3/4/5 + CM3/4/5 + Zero 2)"
    echo "  Payload files: ${#ADD_FILES[@]}"
    echo "  Extra binaries: ${#ADD_BINARIES[@]}"
    echo ""
    echo "To boot a Pi over USB:"
    echo "  rpiboot -d $USBBOOT_DIR"
else
    # ---- normal mode: deploy to local boot partition via tryboot ----
    if [ "$DRY_RUN" = "1" ]; then
        echo ""
        echo -e "${BOLD}Dry run — the following would be written to $BOOT_DIR:${NC}"
        echo ""
        echo "  COPY  $OUTPUT_GZ -> $BOOT_DIR/initramfs-tryboot.gz ($SIZE_KB KB)"
        echo ""
        echo "  CREATE $BOOT_DIR/tryboot.txt:"
        echo "    # Tryboot config — used for one-shot initramfs boot"
        echo "    # A hard reboot or power cycle will ignore this and use config.txt"
        echo "    initramfs initramfs-tryboot.gz followkernel"
        echo "    cmdline cmdline-tryboot.txt"
        echo ""
        echo "  CREATE $BOOT_DIR/cmdline-tryboot.txt:"
        echo "    console=serial0,115200 console=tty1"
        echo ""
        echo "  REBOOT with: reboot \"0 tryboot\""
        echo ""
        echo "  config.txt: NOT modified"
        echo "  Payload files: ${#ADD_FILES[@]}"
        echo "  Extra binaries: ${#ADD_BINARIES[@]}"
        exit 0
    fi

    if [ "$AUTO_YES" = "0" ] && [ "$NO_REBOOT" = "0" ]; then
        echo ""
        echo -e "${YELLOW}This will deploy an initramfs and reboot into it via tryboot.${NC}"
        echo -e "${YELLOW}A hard reboot or power cycle will always return to the normal system.${NC}"
        read -rp "Deploy and reboot now? [y/N]: " CONFIRM
        case "$CONFIRM" in
            [yY]|[yY][eE][sS]) ;;
            *) echo "Aborted. Initramfs built but not deployed."; exit 0 ;;
        esac
    fi

    echo ""
    echo "Deploying to $BOOT_DIR (tryboot)..."
    cp "$OUTPUT_GZ" "$BOOT_DIR/initramfs-tryboot.gz"
    echo "  Copied: initramfs-tryboot.gz"

    # tryboot.txt — loaded instead of config.txt on tryboot
    cat > "$BOOT_DIR/tryboot.txt" <<'TRYBOOT_CFG'
# Tryboot config — used for one-shot initramfs boot
# A hard reboot or power cycle will ignore this and use config.txt
initramfs initramfs-tryboot.gz followkernel
cmdline cmdline-tryboot.txt
TRYBOOT_CFG
    echo "  Created: tryboot.txt"

    # Separate cmdline for tryboot
    echo "console=serial0,115200 console=tty1" > "$BOOT_DIR/cmdline-tryboot.txt"
    echo "  Created: cmdline-tryboot.txt"

    sync

    echo ""
    echo -e "${GREEN}Initramfs deployed via tryboot.${NC}"
    echo "  Size: $SIZE_KB KB"
    echo "  Payload files: ${#ADD_FILES[@]}"
    echo "  Extra binaries: ${#ADD_BINARIES[@]}"
    echo "  config.txt: NOT modified"
    echo ""

    # Reboot handling
    if [ "$NO_REBOOT" = "1" ]; then
        : # Caller handles reboot via: reboot "0 tryboot"
    else
        echo "Rebooting into tryboot..."
        reboot "0 tryboot"
    fi
fi

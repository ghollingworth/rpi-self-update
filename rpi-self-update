#!/bin/bash
set -euo pipefail

# rpi-self-update — prepare a Raspberry Pi for self-update flash
#
# Usage: sudo ./rpi-self-update --url URL --device DEV --cloudinit DIR [options] [-y]

DATA_DIR="/usr/share/rpi-self-update"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    echo "Usage: sudo $0 --url URL --device DEV --cloudinit DIR [options] [-y]"
    echo ""
    echo "Required:"
    echo "  --url URL         Image download URL"
    echo "  --device DEV      Target block device"
    echo "  --cloudinit DIR   Directory containing cloud-init files"
    echo ""
    echo "Optional:"
    echo "  --no-verify       Skip SHA256 verification"
    echo "  --sha256 HASH     Expected SHA256 of extracted image"
    echo "  --image-size N    Expected size in bytes of extracted image"
    echo "  --image-name NAME Human-readable image name"
    echo "  --preserve-home   Backup and restore /home across flash"
    echo "  --preserve-ssh    Backup and restore /etc/ssh host keys across flash"
    echo "  --wifi-ssid SSID  WiFi SSID (fallback if Ethernet unavailable)"
    echo "  --wifi-psk PSK    WiFi password (hashed with wpa_passphrase)"
    echo "  -y, --yes         Skip confirmation prompt"
    echo ""
    exit 1
}

die() {
    echo -e "${RED}ERROR: $*${NC}" >&2
    exit 1
}

# Parse arguments
IMAGE_URL=""
TARGET_DEVICE=""
CLOUDINIT_DIR=""
NO_VERIFY=0
IMAGE_SHA256=""
IMAGE_SIZE=0
IMAGE_NAME=""
PRESERVE_HOME=0
PRESERVE_SSH=0
WIFI_SSID=""
WIFI_PSK=""
AUTO_YES=0

while [ $# -gt 0 ]; do
    case "$1" in
        --url)           IMAGE_URL="$2"; shift 2 ;;
        --device)        TARGET_DEVICE="$2"; shift 2 ;;
        --cloudinit)     CLOUDINIT_DIR="$2"; shift 2 ;;
        --no-verify)     NO_VERIFY=1; shift ;;
        --sha256)        IMAGE_SHA256="$2"; shift 2 ;;
        --image-size)    IMAGE_SIZE="$2"; shift 2 ;;
        --image-name)    IMAGE_NAME="$2"; shift 2 ;;
        --preserve-home) PRESERVE_HOME=1; shift ;;
        --preserve-ssh)  PRESERVE_SSH=1;  shift ;;
        --wifi-ssid)     WIFI_SSID="$2"; shift 2 ;;
        --wifi-psk)      WIFI_PSK="$2"; shift 2 ;;
        -y|--yes)        AUTO_YES=1; shift ;;
        --help|-h)       usage ;;
        *)               die "Unknown option: $1" ;;
    esac
done

# Validate required args
[ -n "$IMAGE_URL" ]    || { usage; }
[ -n "$TARGET_DEVICE" ] || { usage; }
[ -n "$CLOUDINIT_DIR" ] || { usage; }

# Check root
[ "$(id -u)" -eq 0 ] || die "Must be run as root"

# Check payload directory exists
[ -d "$DATA_DIR/payload" ] || die "payload/ directory not found"

# Validate inputs
[ -b "$TARGET_DEVICE" ] || die "$TARGET_DEVICE is not a block device"
[ -f "$CLOUDINIT_DIR/user-data" ] || die "$CLOUDINIT_DIR/user-data not found"

echo -e "${BOLD}Raspberry Pi Self-Update${NC}"
echo ""

# Temp files for cleanup
TMPDIR_CONF=""
STAGED_CLOUDINIT=""
cleanup() {
    [ -n "$TMPDIR_CONF" ] && rm -rf "$TMPDIR_CONF"
    [ -n "$STAGED_CLOUDINIT" ] && rm -rf "$STAGED_CLOUDINIT"
}
trap cleanup EXIT

# If --no-verify, clear verification fields
if [ "$NO_VERIFY" = "1" ]; then
    IMAGE_SHA256=""
    IMAGE_SIZE=0
fi

# Identify boot device
ROOT_DEV=$(findmnt -n -o SOURCE / 2>/dev/null || mount | grep ' on / ' | awk '{print $1}')
# Resolve stable-alias root sources (e.g. /dev/disk/by-slot/system, by-uuid,
# by-partuuid) to the real /dev node, so whole-disk detection and the
# self-update comparison below work on images that mount root via an alias.
ROOT_DEV=$(readlink -f "$ROOT_DEV" 2>/dev/null || echo "$ROOT_DEV")
case "$ROOT_DEV" in
    /dev/mmcblk*p*|/dev/nvme*p*)
        BOOT_DISK=$(echo "$ROOT_DEV" | sed 's/p[0-9]*$//');;
    /dev/sd*)
        BOOT_DISK=$(echo "$ROOT_DEV" | sed 's/[0-9]*$//');;
    *)
        BOOT_DISK=$(echo "$ROOT_DEV" | sed 's/[0-9]*$//');;
esac

# Find boot partition PARTUUID
BOOT_PART="${BOOT_DISK}p1"
[ -b "$BOOT_PART" ] || BOOT_PART="${BOOT_DISK}1"
BOOT_PART_PARTUUID=$(blkid -s PARTUUID -o value "$BOOT_PART" 2>/dev/null || echo "")

# Detect self-update (target == boot device)
target_real=$(readlink -f "$TARGET_DEVICE")
boot_real=$(readlink -f "$BOOT_DISK")
SELF_UPDATE=0
if [ "$target_real" = "$boot_real" ]; then
    SELF_UPDATE=1
fi

# Hash WiFi PSK so plaintext never lands on the vfat boot partition.
# wpa_passphrase SSID PSK prints a config block; we extract the psk= line.
WIFI_PSK_HASH=""
if [ -n "$WIFI_SSID" ] && [ -n "$WIFI_PSK" ]; then
    # NetworkManager may hand us an already-derived 64-hex-char PSK rather than
    # a plaintext passphrase (e.g. WiFi configured with a raw key). That is
    # exactly the value wpa_supplicant.conf wants, so use it verbatim.
    # wpa_passphrase only accepts 8..63 char passphrases and would reject a
    # 64-char key — producing an empty hash and aborting the whole prepare.
    if [[ "$WIFI_PSK" =~ ^[0-9a-fA-F]{64}$ ]]; then
        WIFI_PSK_HASH="$WIFI_PSK"
    else
        command -v wpa_passphrase >/dev/null 2>&1 || die "wpa_passphrase not found (install wpasupplicant)"
        WIFI_PSK_HASH=$(wpa_passphrase "$WIFI_SSID" "$WIFI_PSK" 2>/dev/null | awk -F= '/^[[:space:]]*psk=/ {print $2; exit}')
        [ -n "$WIFI_PSK_HASH" ] || die "wpa_passphrase failed to hash PSK"
    fi
fi

# Display summary
echo "Image:  ${IMAGE_NAME:-unknown}"
echo "URL:    $IMAGE_URL"
echo "Target: $TARGET_DEVICE"
echo "SHA256: ${IMAGE_SHA256:-none}"
echo "Self:   $SELF_UPDATE"
echo "Home:   $([ "$PRESERVE_HOME" = "1" ] && echo "preserve" || echo "no")"
echo "SSH:    $([ "$PRESERVE_SSH"  = "1" ] && echo "preserve host keys" || echo "no")"
echo "WiFi:   ${WIFI_SSID:-none}"
echo ""

# Generate config — use a temp dir so the file has the right basename
TMPDIR_CONF=$(mktemp -d /tmp/rpi-self-update.XXXXXX)
TMPCONF="$TMPDIR_CONF/selfupdate.conf"
cat > "$TMPCONF" <<EOF
MODE=flash
IMAGE_URL=$IMAGE_URL
IMAGE_SHA256=$IMAGE_SHA256
IMAGE_SIZE=$IMAGE_SIZE
IMAGE_NAME="$IMAGE_NAME"
TARGET_DEVICE=$TARGET_DEVICE
BOOT_PARTUUID=${BOOT_PART_PARTUUID:-}
SELF_UPDATE=$SELF_UPDATE
PRESERVE_HOME=$PRESERVE_HOME
PRESERVE_SSH=$PRESERVE_SSH
WIFI_SSID="$WIFI_SSID"
WIFI_PSK_HASH=$WIFI_PSK_HASH
EOF

# Stage cloud-init directory with expected basename
STAGED_CLOUDINIT=$(mktemp -d /tmp/selfupdate-cloudinit.XXXXXX)
rm -rf "$STAGED_CLOUDINIT"
mkdir -p "$STAGED_CLOUDINIT"
cp "$CLOUDINIT_DIR"/* "$STAGED_CLOUDINIT"/
# Rename to expected basename
STAGED_CLOUDINIT_FINAL="$(dirname "$STAGED_CLOUDINIT")/selfupdate-cloudinit"
rm -rf "$STAGED_CLOUDINIT_FINAL"
mv "$STAGED_CLOUDINIT" "$STAGED_CLOUDINIT_FINAL"
STAGED_CLOUDINIT="$STAGED_CLOUDINIT_FINAL"
echo "  Staged cloud-init files"

# Auto-generate cmdline-append if the caller's cloudinit dir didn't provide one.
# Without ds=nocloud on the kernel command line the new image's cloud-init can't
# locate the NoCloud datasource and never applies user-data — so the user
# isn't created and SSH never becomes reachable. rpi-self-update-cli already
# generates this; mirror it here so direct callers (CI, automation) don't
# need to know.
if [ ! -f "$STAGED_CLOUDINIT/cmdline-append" ]; then
    INSTANCE_ID="selfupdate-$(date +%s)"
    echo "ds=nocloud;i=$INSTANCE_ID" > "$STAGED_CLOUDINIT/cmdline-append"
    echo "  Auto-generated cmdline-append (instance-id $INSTANCE_ID)"
fi

# Build initramfs args
INITRAMFS_ARGS=(
    --add-file "$DATA_DIR/payload/initramfs-run"
    --add-file "$DATA_DIR/payload/flash.sh"
    --add-file "$DATA_DIR/payload/preserve-home.sh"
    --add-file "$DATA_DIR/payload/preserve-ssh.sh"
    --add-file "$TMPCONF"
    --add-file "$STAGED_CLOUDINIT"
    --add-binary /usr/sbin/e2fsck
    --add-binary /usr/sbin/resize2fs
    --add-binary /usr/sbin/mke2fs
    --add-binary /usr/sbin/sfdisk
    --no-reboot
)

echo "Calling rpi-initramfs..."
echo ""
rpi-initramfs "${INITRAMFS_ARGS[@]}"

# Print summary
echo ""
echo -e "${GREEN}Preparation complete.${NC}"
echo ""

echo "Ready for flash. The system will:"
echo "  - Boot into the self-update initramfs"
echo "  - Set up network"
if [ "$PRESERVE_HOME" = "1" ] && [ "$SELF_UPDATE" = "1" ]; then
    echo "  - Backup /home to RAM"
fi
if [ "$PRESERVE_SSH" = "1" ] && [ "$SELF_UPDATE" = "1" ]; then
    echo "  - Backup /etc/ssh host keys to RAM"
fi
echo "  - Download and write the image to $TARGET_DEVICE"
echo "  - Verify the written data"
if [ "$PRESERVE_HOME" = "1" ] && [ "$SELF_UPDATE" = "1" ]; then
    echo "  - Restore /home from backup"
fi
if [ "$PRESERVE_SSH" = "1" ] && [ "$SELF_UPDATE" = "1" ]; then
    echo "  - Restore /etc/ssh host keys"
fi
echo "  - Reboot"

echo ""
if [ "$AUTO_YES" = "1" ]; then
    echo "Rebooting into tryboot..."
    reboot "0 tryboot"
else
    echo "To proceed: sudo reboot '0 tryboot'"
fi
